# Environment Variables for GreenHire
# Copy this to .env.local and fill in your values

# Appwrite Core
NEXT_PUBLIC_APPWRITE_ENDPOINT=""
NEXT_PUBLIC_APPWRITE_PROJECT_ID=""
APPWRITE_API_KEY="your-api-key"

# Appwrite Database & Collections
NEXT_PUBLIC_APPWRITE_DATABASE_ID="your-database-id"
NEXT_PUBLIC_APPWRITE_JOBS_COLLECTION_ID="your-jobs-coll-id"
NEXT_PUBLIC_APPWRITE_SUBSCRIBERS_COLLECTION_ID="your-subs-coll-id"
NEXT_PUBLIC_APPWRITE_PAYMENTS_COLLECTION_ID="your-payments-coll-id"

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=

# Site config
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# Admin Defaults (used by your Appwrite setup logic if applicable)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_password
